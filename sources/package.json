{
  "name": "acf-blocks-theme",
  "version": "13.0.0",
  "description": "Starter pack for WordPress development",
  "exports": "./gulpfile.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"gulp\" \"webpack --mode development --watch\"",
    "release": "concurrently \"gulp release\" \"webpack --mode production\"",
    "eslint": "npx eslint js blocks",
    "format": "prettier --write js/**/*.js blocks/**/*.js",
    "check-updates": "ncu",
    "upgrade-deps": "ncu -u && npm install"
  },
  "engines": {
    "node": ">=20"
  },
  "author": {
