    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@eslint/js": "^10.0.1",
    "babel-loader": "^10.1.1",
    "browser-sync": "^3.0.4",
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-webpack-plugin": "^6.0.0",
    "glob": "^13.0.6",
    "globals": "^17.5.0",
    "gulp": "^5.0.1",
    "gulp-autoprefixer": "^10.0.0",
    "gulp-cached": "^1.1.1",
    "gulp-debug": "^5.0.1",
